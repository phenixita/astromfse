---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clients } from '../data/clients';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const heroVideoUrl = 'https://mfitcontent.blob.core.windows.net/static/intro-mfse.mp4';
const toBase = (path: string) => path.startsWith('/') ? `${base}${path.slice(1)}` : `${base}${path}`;
const testimonials = [
  {
    quote: 'Ho avuto il piacere di lavorare con Michele su un progetto di riorganizzazione interna del processo di sviluppo software. Il suo approccio pragmatico, unito a una solida competenza tecnica e metodologica, ci ha permesso di affrontare il cambiamento in modo graduale ma concreto, portando valore al team e all\'azienda.',
    author: 'Ruggero Beretta',
    role: 'CEO — STARCH SRL',
    link: 'https://www.linkedin.com/in/ruggero-beretta-8a49a3/',
    initials: 'RB',
    featured: true,
  },
  {
    quote: 'Best-in-class DevOps consulting. Michele explained everything with exceptional clarity and effectiveness. We also moved straight into practical applications.',
    author: 'Francesco Bonizzi',
    role: 'CTO @ Tuduu',
    link: 'https://it.trustpilot.com/reviews/65755f90362d2a4f4032aabc',
    initials: 'FB',
  },
  {
    quote: 'I believe Michele’s approach was dynamic and structured in a truly positive way, ensuring that attention never dropped.',
    author: 'Maurizio Amoroso',
    role: 'Developer',
    link: 'https://it.trustpilot.com/reviews/65fda37979f8917a1c3075a4',
    initials: 'MA',
  },
  {
    quote: 'Molto chiaro il processo e l\'empatia che Michele ha saputo creare è stata fondamentale per la buona riuscita del corso.',
    author: 'Stefano Polastri',
    role: 'CEO',
    link: 'https://it.trustpilot.com/reviews/6891eff3323f0e2ca0420810',
    initials: 'SP',
  },
  {
    quote: 'An excellent learning experience—clear, comprehensive, and dynamic. The balance between practical and theoretical parts always kept my attention fully engaged.',
    author: 'Alberto',
    role: 'Trustpilot Review',
    link: 'https://it.trustpilot.com/reviews/65fda391c6a910c93058712f',
    initials: 'AL',
  },
  {
    quote: 'I really appreciated the engagement of people through the labs. The explanations were excellent.',
    author: 'Gian Piero Marani',
    role: 'Project Manager',
    link: 'https://it.trustpilot.com/reviews/67a31eebc21ef6ccda2bec17',
    initials: 'GM',
  },
  {
    quote: 'Excellent experience—an instructor who is well-prepared and engaging, with plenty of practical exercises to keep things interesting.',
    author: 'Alberto Strina',
    role: 'System Administrator',
    link: 'https://it.trustpilot.com/reviews/65fda29bde7549a2d20e5171',
    initials: 'AS',
  },
  {
    quote: 'Il miglior corso a cui abbia mai partecipato. Sa come tenere attiva l\'attenzione e coinvolgere i partecipanti con un equilibrio ottimo tra teoria e pratica.',
    author: 'Davide Bertocchi',
    role: 'CTO — Tig Factory',
    link: 'https://it.trustpilot.com/reviews/686e72def341ff2191901ddf',
    initials: 'DB',
  },
  {
    quote: 'Non ho mai visto una persona entrare in un\'azienda e in così poco tempo portare tanta innovazione in termini di DevOps, processi di automatizzazione e deploy.',
    author: 'Andrea Ferrari',
    role: 'Software Developer',
    initials: 'AF',
  },
  {
    quote: 'The course is very well-structured, with a good balance between theory, practice, recaps, and engagement.',
    author: 'Americo Scanga',
    role: 'System Administrator Manager',
    link: 'https://it.trustpilot.com/reviews/65fda2dbfc3455c0b63e5970',
    initials: 'AM',
  },
];
---

<BaseLayout title="Michele Ferracin — #1 Software Engineering Consultant in Italia | DevOps, CI/CD, Organizzazione dei team" description="Michele Ferracin: consulente software engineering in Italia. Specializzato in DevOps, CI/CD, organizzazione dei team, Platform Engineering, Kubernetes, Kanban e AI per lo sviluppo software. Trasformo le software factory.">

  <link slot="head" rel="preload" href={heroVideoUrl} as="video" type="video/mp4" />

  <!-- HERO -->
  <section class="hero hero--with-video">
    <img src={base + "images/hero-home.jpg"} alt="Michele Ferracin - Software Engineering Consultant" class="hero__bg" loading="eager" />
    <div class="container">
      <div class="hero__content">
        <span class="hero__badge">#1 Software Engineering Consultant in Italia</span>
        <h1>Trasformo il caos in <span class="highlight">software che funziona</span></h1>
        <p class="hero__subtitle">
          Aiuto le aziende italiane a costruire software migliore attraverso DevOps, organizzazione dei team, Platform Engineering e pratiche moderne di ingegneria del software. Meno dolore nei rilasci, più valore per il business.
        </p>
        <div class="hero__actions">
          <a href={base + "contact"} class="btn btn--primary">Parliamo del tuo progetto →</a>
          <a href={base + "blog"} class="btn btn--outline">Leggi il Blog</a>
        </div>
      </div>
      <div class="hero__video">
        <video
          src={heroVideoUrl}
          autoplay
          muted
          loop
          playsinline
          controls
          preload="metadata"
          aria-label="Video di presentazione di Michele Ferracin"
        >
          Il tuo browser non supporta il tag video.
        </video>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats stats--story">
    <div class="container">
      <div class="stats-story">
        <p class="stats-story__lead">
          Porto ordine nelle software factory con un approccio pratico: meno attrito nei rilasci, piu visibilita sui colli di bottiglia e decisioni guidate dai dati.
        </p>
        <div class="stats-story__metrics">
          <div class="stats-story__metric">
            <div class="stat__number" data-counter-target="15" data-counter-suffix="+">15+</div>
            <div class="stat__label">Anni di esperienza</div>
          </div>
          <div class="stats-story__metric">
            <div class="stat__number" data-counter-target="150" data-counter-suffix="+">150+</div>
            <div class="stat__label">Articoli pubblicati</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO LOGOS -->
  <section class="logo-marquee" aria-label="Portfolio clienti">
    <div class="logo-marquee__track">
      <div class="logo-marquee__group">
        {clients.map((client) => (
          <div class="logo-marquee__item">
            <img src={base + client.logo.slice(1)} alt={client.name} loading="lazy" />
          </div>
        ))}
      </div>
      <div class="logo-marquee__group" aria-hidden="true">
        {clients.map((client) => (
          <div class="logo-marquee__item">
            <img src={base + client.logo.slice(1)} alt="" role="presentation" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section section--light home-services">
    <div class="container">
      <div class="home-services__intro">
        <p class="home-services__eyebrow">Come posso aiutarti</p>
        <h2>Un percorso concreto per trasformare la tua software factory</h2>
        <p>
          Un percorso concreto per trasformare la tua software factory: organizzazione, delivery e piattaforma lavorano insieme.
        </p>
      </div>
      <div class="home-services__ticker" aria-hidden="true">
        <span>DevOps</span>
        <span>CI/CD</span>
        <span>Organizzazione team</span>
        <span>Kubernetes</span>
        <span>Platform Engineering</span>
        <span>AI nel workflow</span>
      </div>
      <div class="services-editorial services-editorial--split">
        <article class="service-row service-row--split">
          <div class="service-row__head">
            <span class="service-row__number">01</span>
            <p class="service-row__kicker">Delivery senza colli di bottiglia</p>
          </div>
          <h3>DevOps, CI/CD e DevSecOps come sistema unico</h3>
          <p>
            Imposto pipeline, quality gates e sicurezza by design per accelerare i rilasci senza compromettere affidabilita e compliance.
          </p>
          <ul class="service-row__list">
            <li>Pipeline automatizzate e trunk-based development</li>
            <li>Controlli di sicurezza integrati nel flusso di delivery</li>
          </ul>
        </article>

        <article class="service-row service-row--split">
          <div class="service-row__head">
            <span class="service-row__number">02</span>
            <p class="service-row__kicker">Organizzazione e flusso del valore</p>
          </div>
          <h3>Organizzazione dei team e Kanban orientati all'outcome</h3>
          <p>
            Disegno strutture di team e metriche operative per ridurre il WIP, migliorare la prevedibilita e aumentare la velocita decisionale.
          </p>
          <ul class="service-row__list">
            <li>Allineamento tra Stream-aligned e Platform teams</li>
            <li>DORA metrics, lead time e throughput per il miglioramento continuo</li>
          </ul>
        </article>

        <article class="service-row service-row--split">
          <div class="service-row__head">
            <span class="service-row__number">03</span>
            <p class="service-row__kicker">Piattaforma moderna e AI applicata</p>
          </div>
          <h3>Cloud, Kubernetes e AI nel workflow quotidiano</h3>
          <p>
            Porto una base cloud-native robusta e introduco pratiche AI utili al team, con processi ripetibili e misurabili.
          </p>
          <ul class="service-row__list">
            <li>Architetture Kubernetes scalabili e osservabili</li>
            <li>AI coding assistants integrati nelle pratiche di engineering</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="home-split-band" aria-label="Risultati attesi">
    <div class="container home-split-band__inner">
      <p>
        Meno attrito nei rilasci.<span> Piu prevedibilita.</span>
        <strong>Piu valore per il business.</strong>
      </p>
    </div>
  </section>

  <div class="section-image-break section-image-break--overlay">
    <img src={base + "images/hero-services.jpg"} alt="Team di sviluppo al lavoro in un ambiente moderno" loading="lazy" />
  </div>

  <!-- TESTIMONIALS -->
  <section class="section home-testimonials">
    <div class="container">
      <h2 class="text-center home-testimonials__title">Cosa dicono di me</h2>
      <p class="text-center" style="color: var(--color-text-light); max-width: 660px; margin: 0 auto;">
        Feedback reali da clienti, corsisti e manager.
      </p>
      <div class="testimonials-grid">
        {testimonials.map((testimonial) => (
          <article class:list={['testimonial-card', { 'testimonial-card--featured': testimonial.featured }]}>
            <div class="testimonial-card__stars">★★★★★</div>
            <blockquote class="testimonial-card__quote">{testimonial.quote}</blockquote>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar">{testimonial.initials}</div>
              <div>
                <div class="testimonial-card__name">{testimonial.author}</div>
                <div class="testimonial-card__role">{testimonial.role}</div>
                {testimonial.link && (
                  <a href={testimonial.link} target="_blank" rel="nofollow noopener" class="testimonial-card__source">
                    Leggi recensione
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta cta--home">
    <div class="container">
      <div class="cta--home__panel">
        <p class="cta--home__eyebrow">Partiamo dal prossimo rilascio</p>
        <h2>Pronto a trasformare la tua software factory?</h2>
        <p>Contattami per una consulenza gratuita. Insieme troveremo il modo migliore per migliorare il tuo processo di sviluppo.</p>
        <a href={base + "contact"} class="btn btn--primary">Parliamo →</a>
      </div>
    </div>
  </section>

  <style>
    /* Hero video split layout */
    .hero--with-video .container {
      grid-template-columns: 1fr minmax(0, 420px);
    }

    .hero__video {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero__video video {
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      border-radius: 10px;
      box-shadow: 0 12px 30px rgba(var(--color-primary-rgb), 0.18);
    }

    .home-services {
      position: relative;
      overflow: hidden;
      padding-top: clamp(4rem, 8vw, 6rem);
      padding-bottom: clamp(4.5rem, 9vw, 7rem);
      background:
        radial-gradient(circle at 10% 8%, rgba(var(--color-accent-rgb), 0.2), transparent 42%),
        linear-gradient(180deg, rgba(var(--color-light-rgb), 0.78) 0%, var(--color-white) 100%);
    }

    .home-services::after {
      content: '';
      position: absolute;
      inset: auto 0 -1px 0;
      height: 56px;
      background: var(--color-white);
      clip-path: polygon(0 100%, 100% 30%, 100% 100%);
      pointer-events: none;
    }

    .home-services__intro {
      max-width: 880px;
      margin-bottom: var(--space-lg);
    }

    .home-services__eyebrow {
      display: inline-flex;
      padding: 0.35rem 0.82rem;
      border-radius: 999px;
      background: rgba(var(--color-primary-rgb), 0.1);
      color: var(--color-primary);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: var(--space-sm);
    }

    .home-services__intro h2 {
      font-size: clamp(2rem, 5vw, 3.4rem);
      line-height: 1.02;
      letter-spacing: -0.02em;
      margin-bottom: var(--space-md);
      max-width: 18ch;
    }

    .home-services__intro p {
      font-size: clamp(1rem, 1.8vw, 1.25rem);
      color: var(--color-text-light);
      max-width: 64ch;
    }

    .home-services__ticker {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-bottom: clamp(1.3rem, 3vw, 2rem);
    }

    .home-services__ticker span {
      padding: 0.43rem 0.9rem;
      border-radius: 999px;
      background: rgba(var(--color-primary-rgb), 0.08);
      color: var(--color-secondary);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .services-editorial--split {
      margin-top: 0;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: clamp(1rem, 2.3vw, 1.8rem);
    }

    .service-row--split {
      grid-column: span 8;
      max-width: none;
      border-radius: 24px;
      border: 1px solid rgba(var(--color-primary-rgb), 0.12);
      box-shadow: 0 22px 56px rgba(var(--color-primary-rgb), 0.12);
      padding: clamp(1.3rem, 2.5vw, 2rem);
      background: rgba(var(--color-light-rgb), 0.68);
      backdrop-filter: blur(3px);
      position: relative;
      overflow: hidden;
    }

    .service-row--split::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 6px;
      background: linear-gradient(180deg, var(--color-cta), var(--color-accent));
    }

    .service-row--split:nth-child(2) {
      grid-column: 4 / -1;
    }

    .service-row--split:nth-child(3) {
      grid-column: 1 / span 8;
    }

    .service-row__head {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: var(--space-sm);
    }

    .service-row__number {
      font-size: clamp(1.4rem, 2.7vw, 2rem);
      line-height: 1;
      font-weight: 800;
      color: rgba(var(--color-primary-rgb), 0.28);
    }

    .service-row--split h3 {
      font-size: clamp(1.3rem, 2.4vw, 2rem);
      line-height: 1.12;
      margin-bottom: var(--space-sm);
      max-width: 26ch;
    }

    .service-row--split p {
      color: var(--color-text);
      max-width: 62ch;
    }

    .service-row--split .service-row__list {
      gap: 0.5rem;
    }

    .service-row--split .service-row__list li {
      color: var(--color-secondary);
      font-size: 0.94rem;
    }

    .home-split-band {
      position: relative;
      margin-top: -1px;
      background: linear-gradient(115deg, var(--color-primary) 0%, var(--color-secondary) 68%, #1e2a3c 100%);
      color: var(--color-white);
      overflow: hidden;
    }

    .home-split-band::before,
    .home-split-band::after {
      content: '';
      position: absolute;
      left: 0;
      width: 100%;
      height: 30px;
      background: var(--color-white);
      opacity: 0.92;
    }

    .home-split-band::before {
      top: 0;
      clip-path: polygon(0 0, 100% 0, 100% 100%);
    }

    .home-split-band::after {
      bottom: 0;
      clip-path: polygon(0 0, 100% 100%, 0 100%);
    }

    .home-split-band__inner {
      padding: clamp(2.6rem, 6vw, 4.8rem) 0;
    }

    .home-split-band p {
      margin: 0;
      font-size: clamp(1.45rem, 4vw, 3rem);
      line-height: 1.06;
      font-weight: 700;
      letter-spacing: -0.02em;
      max-width: 20ch;
    }

    .home-split-band span {
      color: var(--color-accent);
    }

    .home-split-band strong {
      display: block;
      margin-top: 0.4rem;
      font-size: clamp(1rem, 2.3vw, 1.7rem);
      font-weight: 500;
      color: rgba(var(--color-light-rgb), 0.9);
    }

    .home-testimonials {
      background:
        radial-gradient(circle at 86% 9%, rgba(var(--color-accent-rgb), 0.16), transparent 35%),
        linear-gradient(180deg, rgba(var(--color-light-rgb), 0.44) 0%, var(--color-white) 100%);
      padding-top: clamp(3.5rem, 7vw, 5rem);
    }

    .home-testimonials__title {
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      letter-spacing: -0.02em;
    }

    .cta--home {
      background: transparent;
      text-align: left;
      padding: clamp(1.6rem, 3.4vw, 2.4rem) 0 clamp(4.2rem, 8vw, 6rem);
      color: var(--color-light);
    }

    .cta--home__panel {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      padding: clamp(1.8rem, 4vw, 3rem);
      background: linear-gradient(132deg, var(--color-primary) 0%, #172131 52%, var(--color-secondary) 100%);
      box-shadow: none;
    }

    .cta--home__panel::after {
      content: '';
      position: absolute;
      width: clamp(170px, 30vw, 360px);
      aspect-ratio: 1;
      border-radius: 50%;
      background: rgba(var(--color-accent-rgb), 0.2);
      right: -8%;
      bottom: -38%;
      pointer-events: none;
    }

    .cta--home__eyebrow {
      display: inline-block;
      font-size: 0.74rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-accent);
      margin-bottom: var(--space-sm);
    }

    .cta--home h2 {
      color: var(--color-white);
      font-size: clamp(2rem, 4.6vw, 3.2rem);
      line-height: 1.04;
      margin-bottom: var(--space-md);
      max-width: 17ch;
    }

    .cta--home p {
      color: rgba(var(--color-light-rgb), 0.86);
      margin: 0 0 var(--space-lg);
      max-width: 55ch;
      font-size: clamp(1rem, 1.8vw, 1.18rem);
    }

    @media (max-width: 960px) {
      .hero--with-video .container {
        grid-template-columns: 1fr minmax(0, 320px);
      }

      .service-row--split,
      .service-row--split:nth-child(2),
      .service-row--split:nth-child(3) {
        grid-column: 1 / -1;
      }

      .home-split-band p {
        max-width: 100%;
      }
    }

    @media (max-width: 768px) {
      .hero--with-video .container {
        grid-template-columns: 1fr;
      }
      .hero__video {
        justify-content: center;
        margin-top: var(--space-lg);
      }
      .hero__video video {
        max-width: 480px;
      }

      .home-services {
        padding-top: var(--space-2xl);
      }

      .home-services__ticker span {
        font-size: 0.72rem;
      }

      .home-split-band::before,
      .home-split-band::after {
        height: 20px;
      }

      .cta--home__panel {
        border-radius: 20px;
      }

      .cta--home h2 {
        max-width: none;
      }
    }
  </style>

  <script>
    const counters = Array.from(document.querySelectorAll('.stats-story .stat__number[data-counter-target]'));
    if (counters.length > 0) {
      const formatValue = (value, suffix) => `${value.toLocaleString('it-IT')}${suffix}`;
      const animateCounter = (counter) => {
        const target = Number(counter.dataset.counterTarget || '0');
        const suffix = counter.dataset.counterSuffix || '';
        const duration = 1200;
        const start = performance.now();

        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = Math.round(target * eased);
          counter.textContent = formatValue(value, suffix);
          if (progress < 1) {
            requestAnimationFrame(tick);
          }
        };

        requestAnimationFrame(tick);
      };

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        counters.forEach((counter) => {
          const target = Number(counter.dataset.counterTarget || '0');
          const suffix = counter.dataset.counterSuffix || '';
          counter.textContent = formatValue(target, suffix);
        });
      } else {
        const statsSection = document.querySelector('.stats--story');
        if (statsSection) {
          const observer = new IntersectionObserver((entries, obs) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              counters.forEach(animateCounter);
              obs.disconnect();
            }
          }, { threshold: 0.35 });
          observer.observe(statsSection);
        }
      }
    }
  </script>

</BaseLayout>



