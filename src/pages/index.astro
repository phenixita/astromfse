---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const toBase = (path: string) => path.startsWith('/') ? `${base}${path.slice(1)}` : `${base}${path}`;
---

<BaseLayout title="Michele Ferracin — #1 Software Engineering Consultant in Italia | DevOps, CI/CD, Team Topologies" description="Michele Ferracin: consulente software engineering in Italia. Specializzato in DevOps, CI/CD, Team Topologies, Platform Engineering, Kubernetes, Kanban e AI per lo sviluppo software. Trasformo le software factory.">

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero__content">
        <span class="hero__badge">#1 Software Engineering Consultant in Italia</span>
        <h1>Trasformo il caos in <span class="highlight">software che funziona</span></h1>
        <p class="hero__subtitle">
          Aiuto le aziende italiane a costruire software migliore attraverso DevOps, Team Topologies, Platform Engineering e pratiche moderne di ingegneria del software. Meno dolore nei rilasci, più valore per il business.
        </p>
        <div class="hero__actions">
          <a href={base + "contact"} class="btn btn--primary">Parliamo del tuo progetto →</a>
          <a href={base + "blog"} class="btn btn--outline">Leggi il Blog</a>
        </div>
      </div>
      <div class="hero__illustration">
        <img src={base + "images/heroes/homepage.svg"} alt="" role="presentation" width="500" height="417" />
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats stats--story">
    <div class="container">
      <div class="stats-story">
        <p class="stats-story__lead">
          Porto ordine nelle software factory con un approccio pratico: meno attrito nei rilasci, piu visibilita sui colli di bottiglia e decisioni guidate dai dati.
        </p>
        <div class="stats-story__metrics">
          <div class="stats-story__metric">
            <div class="stat__number">15+</div>
            <div class="stat__label">Anni di esperienza</div>
          </div>
          <div class="stats-story__metric">
            <div class="stat__number">150+</div>
            <div class="stat__label">Articoli pubblicati</div>
          </div>
          <div class="stats-story__metric">
            <div class="stat__number">100%</div>
            <div class="stat__label">Focus su risultati</div>
          </div>
          <div class="stats-story__metric">
            <div class="stat__number">ITA</div>
            <div class="stat__label">Focus Italia</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Come posso aiutarti</h2>
      <p class="text-center" style="color: var(--color-text-light); max-width: 680px; margin: 0 auto;">
        Un percorso concreto per trasformare la tua software factory: organizzazione, delivery e piattaforma lavorano insieme.
      </p>
      <div class="services-editorial">
        <article class="service-row">
          <p class="service-row__kicker">Delivery senza colli di bottiglia</p>
          <h3>DevOps, CI/CD e DevSecOps come sistema unico</h3>
          <p>
            Imposto pipeline, quality gates e sicurezza by design per accelerare i rilasci senza compromettere affidabilita e compliance.
          </p>
          <ul class="service-row__list">
            <li>Pipeline automatizzate e trunk-based development</li>
            <li>Controlli di sicurezza integrati nel flusso di delivery</li>
          </ul>
        </article>

        <article class="service-row">
          <p class="service-row__kicker">Organizzazione e flusso del valore</p>
          <h3>Team Topologies e Kanban orientati all'outcome</h3>
          <p>
            Disegno strutture di team e metriche operative per ridurre il WIP, migliorare la prevedibilita e aumentare la velocita decisionale.
          </p>
          <ul class="service-row__list">
            <li>Allineamento tra Stream-aligned e Platform teams</li>
            <li>DORA metrics, lead time e throughput per il miglioramento continuo</li>
          </ul>
        </article>

        <article class="service-row">
          <p class="service-row__kicker">Piattaforma moderna e AI applicata</p>
          <h3>Cloud, Kubernetes e AI nel workflow quotidiano</h3>
          <p>
            Porto una base cloud-native robusta e introduco pratiche AI utili al team, con processi ripetibili e misurabili.
          </p>
          <ul class="service-row__list">
            <li>Architetture Kubernetes scalabili e osservabili</li>
            <li>AI coding assistants integrati nelle pratiche di engineering</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Cosa dicono di me</h2>
      <p class="text-center" style="color: var(--color-text-light); max-width: 660px; margin: 0 auto;">
        Pochi feedback, molto concreti: risultati, impatto e collaborazione.
      </p>
      <div class="testimonials-home">
        <div class="quote-band">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote class="quote-band__quote">
            Ho avuto il piacere di lavorare con Michele su un progetto di riorganizzazione interna del processo di sviluppo software. Il suo approccio pragmatico, unito a una solida competenza tecnica e metodologica, ci ha permesso di affrontare il cambiamento in modo graduale ma concreto, portando valore al team e all'azienda.
          </blockquote>
          <p class="quote-band__author">Ruggero Beretta — CEO, STARCH SRL</p>
        </div>

        <div class="proof-grid">
          <article class="proof-item">
            <h3>DevOps consulting ad alto impatto</h3>
            <p>
              Best-in-class DevOps consulting. Michele explained everything with exceptional clarity and effectiveness. We also moved straight into practical applications.
            </p>
            <p class="proof-item__author">Francesco Bonizzi — CTO @ Tuduu</p>
          </article>

          <article class="proof-item">
            <h3>Innovazione concreta in tempi rapidi</h3>
            <p>
              Non ho mai visto una persona entrare in un'azienda ed in cosi poco tempo portare tanta innovazione in termini di DevOps, processi di automatizzazione e deploy.
            </p>
            <p class="proof-item__author">Andrea Ferrari — Software Developer</p>
          </article>

          <article class="proof-item">
            <h3>Coinvolgimento e attenzione costante</h3>
            <p>
              Il miglior corso a cui abbia mai partecipato. Sa come tenere attiva l'attenzione e coinvolgere i partecipanti con un equilibrio ottimo tra teoria e pratica.
            </p>
            <p class="proof-item__author">Davide Bertocchi — CTO, Tig Factory</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <h2>Pronto a trasformare la tua software factory?</h2>
      <p>Contattami per una consulenza gratuita. Insieme troveremo il modo migliore per migliorare il tuo processo di sviluppo.</p>
      <a href={base + "contact"} class="btn btn--primary">Parliamo →</a>
    </div>
  </section>

</BaseLayout>


