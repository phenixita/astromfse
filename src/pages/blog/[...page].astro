---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection('blog'))
    .filter(p => !p.data.draft)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  return paginate(allPosts, { pageSize: 12 });
}

const { page } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const toBase = (path: string) => path.startsWith('/') ? `${base}${path.slice(1)}` : `${base}${path}`;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
}

function getExcerpt(body: string, maxLen = 140): string {
  const cleaned = body.replace(/^---[\s\S]*?---/, '').replace(/<[^>]+>/g, '').replace(/[#*_\[\]()]/g, '').trim();
  const lines = cleaned.split('\n').filter(l => l.trim().length > 10);
  const text = lines[0] || '';
  return text.length > maxLen ? text.slice(0, maxLen) + '…' : text;
}
---

<BaseLayout title={`Blog${page.currentPage > 1 ? ` — Pagina ${page.currentPage}` : ''} — Michele Ferracin`} description="Articoli su DevOps, CI/CD, organizzazione dei team, Kubernetes, Kanban, metriche DORA, AI coding e pratiche moderne di software engineering. Di Michele Ferracin.">
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Riflessioni su DevOps, software engineering, team di sviluppo e intelligenza artificiale.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <p style="color: var(--color-text-light); margin-bottom: var(--space-lg);">{page.total} articoli pubblicati</p>
      <div class="blog-grid">
        {page.data.map(post => (
          <article class="blog-card">
            <div class="blog-card__body">
              <span class="blog-card__date">{formatDate(post.data.date)}</span>
              <h3 class="blog-card__title">
                <a href={toBase(`/blog/${post.id}`)}>{post.data.title}</a>
              </h3>
              <p class="blog-card__excerpt">{getExcerpt(post.body ?? '')}</p>
              <a href={toBase(`/blog/${post.id}`)} class="blog-card__read-more">Leggi →</a>
            </div>
          </article>
        ))}
      </div>

      {page.lastPage > 1 && (
        <div class="pagination">
          {page.url.prev && <a href={toBase(page.url.prev)}>← Prec</a>}
          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(num => (
            num === page.currentPage
              ? <span class="active">{num}</span>
              : <a href={toBase(num === 1 ? '/blog' : `/blog/${num}`)}>{num}</a>
          ))}
          {page.url.next && <a href={toBase(page.url.next)}>Succ →</a>}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
