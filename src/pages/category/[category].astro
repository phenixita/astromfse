---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories, categoriesBySlug } from '../../data/categories';

export async function getStaticPaths() {
  const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  return categories.map((category) => ({
    params: { category: category.slug },
    props: {
      category,
      posts: posts.filter((post) => post.data.categories?.includes(category.slug)),
    },
  }));
}

const { category, posts } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const toBase = (path: string) => path.startsWith('/') ? `${base}${path.slice(1)}` : `${base}${path}`;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
}

function getExcerpt(body: string, maxLen = 140): string {
  const cleaned = body.replace(/^---[\s\S]*?---/, '').replace(/<[^>]+>/g, '').replace(/[#*_\[\]()]/g, '').trim();
  const lines = cleaned.split('\n').filter(l => l.trim().length > 10);
  const text = lines[0] || '';
  return text.length > maxLen ? text.slice(0, maxLen) + '…' : text;
}

function getCategories(slugs: string[] = []) {
  return slugs.map((slug) => categoriesBySlug.get(slug)).filter(Boolean);
}
---

<BaseLayout
  title={`${category.label} — Categoria Blog | Michele Ferracin`}
  description={`Articoli di Michele Ferracin nella categoria ${category.label}. DevOps, team e software engineering.`}
>
  <div class="page-header">
    <div class="container">
      <span class="hero__badge">Categoria</span>
      <h1>{category.label}</h1>
      <p>{posts.length} articoli su {category.label}.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => {
          const postCategories = getCategories(post.data.categories);

          return (
            <article class="blog-card">
              <div class="blog-card__body">
                {postCategories.length > 0 && (
                  <div class="category-chips" aria-label="Categorie">
                    {postCategories.map((cat) => (
                      <a href={toBase(`/category/${cat.slug}`)} class="category-chip">
                        {cat.label}
                      </a>
                    ))}
                  </div>
                )}
                <span class="blog-card__date">{formatDate(post.data.date)}</span>
                <h3 class="blog-card__title">
                  <a href={toBase(`/${post.data.permalink || post.id.replace(/\.mdx?$/, '')}`)}>{post.data.title}</a>
                </h3>
                <p class="blog-card__excerpt">{getExcerpt(post.body ?? '')}</p>
                <a href={toBase(`/${post.data.permalink || post.id.replace(/\.mdx?$/, '')}`)} class="blog-card__read-more">Leggi →</a>
              </div>
            </article>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="text-center" style="margin-top: var(--space-xl);">
          <p style="color: var(--color-text-light);">Nessun articolo in questa categoria, per ora.</p>
          <a href={base + "blog"} class="btn btn--outline" style="margin-top: var(--space-md);">Torna al Blog</a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
