---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Speaking — Michele Ferracin" description="Sono il tech speaker che stavi cercando. Keynote, tech talk e workshop su DevOps, CI/CD, Team Topologies, Platform Engineering e software engineering.">

  <div class="speaking-hero">
    <img src={base + "images/speaking-hero.jpeg"} alt="Michele Ferracin speaking" class="speaking-hero__img" />
    <div class="speaking-hero__overlay">
      <div class="container">
        <h1>Sono il tech speaker che stavi cercando</h1>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container container--narrow">
      <div style="text-align: center; margin-bottom: var(--space-lg);">
        <a href="https://outlook.office365.com/owa/calendar/MicheleFerracin@limeware.it/bookings/s/yBmhIL2mkESWdD961_3pRw2" target="_blank" rel="nofollow noopener" class="btn btn--primary">Prenota un incontro gratuito senza impegno</a>
      </div>

      <p style="font-size: 1.1rem;">Ogni iniziativa o cambiamento tecnologico coinvolge le <strong>persone prima degli strumenti</strong>.<br/>Di sicuro hai partecipato a lanci di progetti più o meno mirabolanti per vederli fallire qualche settimana dopo.</p>
      <p style="font-size: 1.1rem;">Perché? Perché le persone non sono coinvolte emotivamente.</p>
      <p style="font-size: 1.1rem;">Le persone sono al centro delle iniziative e devono essere coinvolte nella parte emozionale, altrimenti saranno indifferenti all'iniziativa o la vedranno come l'ennesima rottura invece che l'opportunità di miglioramento che tu hai in mente!</p>
      <p style="font-size: 1.1rem;">Con la giusta carica e motivazione le persone accoglieranno con maggiore energia e le probabilità di successo del tuo progetto saliranno!</p>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--space-xl);">I miei numeri</h2>
      <div class="features-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        <div class="feature-card" style="text-align: center;">
          <div class="feature-card__icon">in</div>
          <h3>LinkedIn</h3>
          <p><strong>+1.300</strong> follower<br/><strong>+150.000</strong> utenti raggiunti negli ultimi 365 giorni</p>
        </div>
        <div class="feature-card" style="text-align: center;">
          <div class="feature-card__icon">YT</div>
          <h3>YouTube</h3>
          <p><strong>+3.900</strong> iscritti<br/><strong>+5.000</strong> ore di visualizzato all'anno<br/><strong>+80.000</strong> view/anno</p>
        </div>
        <div class="feature-card" style="text-align: center;">
          <div class="feature-card__icon">U</div>
          <h3>Udemy</h3>
          <p><strong>+1.100</strong> studenti totali<br/><strong>+350</strong> recensioni<br/><strong>4.5/5</strong> media recensioni</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <h2>Media</h2>
      <ul style="list-style: none; padding: 0; margin-top: var(--space-lg);">
        <li style="margin-bottom: var(--space-md); font-size: 1.1rem;"><a href="https://www.youtube.com/@MicheleFerracin/" target="_blank" rel="noopener">Michele Ferracin YouTube Channel</a></li>
        <li style="font-size: 1.1rem;"><a href="https://open.spotify.com/show/0VZQzYCo8Ytp25lZGoBQ8l" target="_blank" rel="noopener">Michele Ferracin Software Engineering Podcast</a></li>
      </ul>
    </div>
  </section>

  <section class="section section--light">
    <div class="container container--narrow">
      <h2 style="margin-bottom: var(--space-xl);">Tech Talks</h2>
      <div class="speaking-talks">
        <div class="speaking-talk">
          <span class="speaking-talk__year">2026</span>
          <div>
            <strong>I microservizi so un'esagerazione? Scopri il monolite modulare in ASP NET Core</strong>
            <span class="speaking-talk__event">SharpCoding, Roma</span>
          </div>
        </div>
        <div class="speaking-talk">
          <span class="speaking-talk__year">2023</span>
          <div>
            <strong>Release Orchestration in Highly regulated environment</strong>
            <span class="speaking-talk__event">DevOps Heroes, Parma</span>
          </div>
        </div>
        <div class="speaking-talk">
          <span class="speaking-talk__year">2020</span>
          <div>
            <strong>Resiliency pattern on Azure</strong>
            <span class="speaking-talk__event">DevOps At Work, Rome</span>
          </div>
        </div>
        <div class="speaking-talk">
          <span class="speaking-talk__year">2019</span>
          <div>
            <strong>Chirp Chirp! Canary Release Strategy with Telemetry for Peaceful Nights</strong>
            <span class="speaking-talk__event">DevOps Heroes, Parma</span>
          </div>
        </div>
        <div class="speaking-talk">
          <span class="speaking-talk__year">2018</span>
          <div>
            <strong>Controlling Chaos</strong>
            <span class="speaking-talk__event">DevOps Heroes, Parma</span>
          </div>
        </div>
        <div class="speaking-talk">
          <span class="speaking-talk__year">2018</span>
          <div>
            <strong>The Three Way of DevOps</strong>
            <span class="speaking-talk__event">DevOps At Work, Rome</span>
          </div>
        </div>
        <div class="speaking-talk">
          <span class="speaking-talk__year">2017</span>
          <div>
            <strong>Continuous Delivery: From Zero to Release with a Click</strong>
            <span class="speaking-talk__event">DevOps Heroes, Parma</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>Vuoi invitarmi al tuo evento?</h2>
      <p>Prenota un incontro gratuito per discutere della tua prossima iniziativa.</p>
      <a href="https://outlook.office365.com/owa/calendar/MicheleFerracin@limeware.it/bookings/s/yBmhIL2mkESWdD961_3pRw2" target="_blank" rel="nofollow noopener" class="btn btn--primary">Prenota un incontro →</a>
    </div>
  </section>

</BaseLayout>

<style>
  .speaking-hero {
    position: relative;
    height: 400px;
    overflow: hidden;
  }

  .speaking-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .speaking-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
  }

  .speaking-hero__overlay h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--color-primary);
    max-width: 700px;
  }

  .speaking-talks {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .speaking-talk {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    align-items: baseline;
    transition: all var(--transition);
  }

  .speaking-talk:hover {
    transform: translateX(4px);
    box-shadow: 0 4px 20px rgba(var(--color-primary-rgb), 0.14);
  }

  .speaking-talk__year {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--color-accent);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .speaking-talk__event {
    display: block;
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-top: 2px;
  }

  @media (max-width: 600px) {
    .speaking-hero {
      height: 280px;
    }

    .speaking-talk {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>


