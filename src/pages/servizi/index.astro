---
import BaseLayout from '../../layouts/BaseLayout.astro';

const bookingUrl = 'https://outlook.office365.com/owa/calendar/MicheleFerracin@limeware.it/bookings/s/yBmhIL2mkESWdD961_3pRw2';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Servizi — Michele Ferracin" description="Consulenza specializzata: Azure DevOps, Kanban, Kubernetes e .NET C# Modernization. Trasforma la tua software factory con un approccio pratico e orientato ai risultati.">

  <div class="page-header">
    <img src={base + "images/hero-services.jpg"} alt="" class="page-header__bg" loading="eager" />
    <div class="container">
      <div class="page-header__text">
        <h1>Servizi</h1>
        <p>Consulenza specializzata per portare la tua software factory al livello successivo.</p>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="features-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">

        <div class="feature-card">
          <div class="feature-card__icon">//</div>
          <h3>Azure DevOps</h3>
          <p>Pipeline CI/CD, Azure Boards, trunk-based development, metriche DORA e automazione completa del ciclo di delivery.</p>
          <a href={base + "servizi/azure-devops"} class="btn btn--outline" style="margin-top: var(--space-md);">Scopri di più →</a>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">WIP</div>
          <h3>Kanban</h3>
          <p>WIP limits, lead time, throughput, continuous improvement. Doma il caos e rendi prevedibile il tuo flusso di lavoro.</p>
          <a href={base + "servizi/kanban"} class="btn btn--outline" style="margin-top: var(--space-md);">Scopri di più →</a>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">K8s</div>
          <h3>Kubernetes</h3>
          <p>Architetture cloud-native, AKS, microservizi, sicurezza cluster, CI/CD con Docker e observability.</p>
          <a href={base + "servizi/kubernetes"} class="btn btn--outline" style="margin-top: var(--space-md);">Scopri di più →</a>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">C#</div>
          <h3>.NET C# Modernization</h3>
          <p>Refactoring, test strategy, debito tecnico, monolite modulare, AI-assisted development per codice .NET legacy.</p>
          <a href={base + "servizi/dotnet-modernization"} class="btn btn--outline" style="margin-top: var(--space-md);">Scopri di più →</a>
        </div>

        <div class="feature-card" style="position: relative;">
          <span class="service-badge beta">beta</span>
          <div class="feature-card__icon">✨</div>
          <h3>AI ALM Adoption</h3>
          <p>Integrazione strategica di AI nell'intero ciclo di sviluppo: planning, coding, testing, deployment. Con governance, quality gate e team upskilling.</p>
          <a href={base + "servizi/ai-alm-adoption"} class="btn btn--outline" style="margin-top: var(--space-md);">Scopri di più →</a>
        </div>

      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>Non sai da dove partire?</h2>
      <p>Prenota un incontro gratuito e senza impegno. Insieme capiremo qual è il percorso giusto per la tua situazione.</p>
      <a href={bookingUrl} target="_blank" rel="nofollow noopener" class="btn btn--primary">Prenota un incontro gratuito →</a>
    </div>
  </section>

  <style>
    .service-badge {
      position: absolute;
      top: var(--space-sm);
      right: var(--space-sm);
      background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
      color: var(--color-white);
      font-weight: 700;
      font-size: 0.75rem;
      padding: 0.3rem 0.6rem;
      border-radius: 4px;
      display: inline-block;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .service-badge.beta {
      background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
    }
  </style>

</BaseLayout>


