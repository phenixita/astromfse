---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const photos = [
  { src: 'gallery/microsoft-event-afternoon.jpg', caption: 'Microsoft Event', size: 'tall' },
  { src: 'gallery/consulting-session.jpg', caption: 'Consulenza sul campo', size: 'wide' },
  { src: 'gallery/microsoft-event-selfie.jpg', caption: 'Networking', size: 'normal' },
  { src: 'gallery/agile-coaching.jpg', caption: 'Agile Coaching', size: 'normal' },
  { src: 'gallery/team-workshop.jpg', caption: 'Workshop di team', size: 'tall' },
  { src: 'gallery/strategy-meeting.jpg', caption: 'Strategia & Visione', size: 'normal' },
  { src: 'gallery/tech-deep-dive.jpg', caption: 'Deep Dive Tecnico', size: 'wide' },
  { src: 'gallery/microsoft-event-morning.jpg', caption: 'Community', size: 'normal' },
  { src: 'gallery/afternoon-session.jpg', caption: 'Sessione pomeridiana', size: 'normal' },
  { src: 'gallery/devops-workshop.jpg', caption: 'DevOps in azione', size: 'tall' },
  { src: 'gallery/morning-kickoff.jpg', caption: 'Kickoff mattutino', size: 'wide' },
  { src: 'gallery/collaboration-day.jpg', caption: 'Collaborazione', size: 'normal' },
  { src: 'gallery/wrap-up-session.jpg', caption: 'Risultati concreti', size: 'normal' },
];
---

<BaseLayout
  title="Gallery — Le cose accadono davvero | Michele Ferracin"
  description="Momenti reali di consulenza, workshop, eventi e collaborazione nelle aziende. Le cose accadono davvero."
>

  <!-- Hero -->
  <section class="gallery-hero">
    <div class="gallery-hero__bg">
      <img src={base + "images/gallery/microsoft-event-afternoon.jpg"} alt="" loading="eager" />
    </div>
    <div class="gallery-hero__overlay"></div>
    <div class="gallery-hero__content">
      <span class="gallery-hero__tag">Sul campo</span>
    </div>
  </section>

  <!-- Gallery Masonry -->
  <section class="gallery-section">
    <div class="gallery-grid">
      {photos.map((photo, i) => (
        <figure class={`gallery-item gallery-item--${photo.size}`} style={`--delay: ${i * 0.06}s`}>
          <div class="gallery-item__img-wrap">
            <img
              src={base + `images/${photo.src}`}
              alt={photo.caption}
              loading="lazy"
              decoding="async"
            />
          </div>
        </figure>
      ))}
    </div>
  </section>

  <!-- Closing statement -->
  <section class="gallery-closing">
    <blockquote>
      "Il software migliore nasce quando le persone si incontrano davvero."
    </blockquote>
  </section>

</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────────────── */
  .gallery-hero {
    position: relative;
    height: 70vh;
    min-height: 420px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }
  .gallery-hero__bg {
    position: absolute;
    inset: 0;
  }
  .gallery-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: saturate(0.85) contrast(1.05);
  }
  .gallery-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(42, 27, 56, 0.92) 0%,
      rgba(42, 27, 56, 0.45) 50%,
      rgba(42, 27, 56, 0.15) 100%
    );
  }
  .gallery-hero__content {
    position: relative;
    z-index: 2;
    padding: var(--space-xl) var(--space-lg);
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }
  .gallery-hero__tag {
    display: inline-block;
    background: var(--color-cta);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.3rem 0.85rem;
    border-radius: 2px;
    margin-bottom: var(--space-sm);
  }
  .gallery-hero__content h1 {
    color: #fff;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 1.08;
    margin: 0 0 var(--space-sm);
    font-weight: 800;
  }
  .gallery-hero__content h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  /* ── Gallery Section ────────────────────────────── */
  .gallery-section {
    padding: var(--space-xl) var(--space-lg);
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ── Masonry Grid ───────────────────────────────── */
  .gallery-grid {
    columns: 3;
    column-gap: var(--space-md);
  }

  .gallery-item {
    break-inside: avoid;
    margin: 0 0 var(--space-md);
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    animation: galleryFadeIn 0.6s ease both;
    animation-delay: var(--delay);
  }
  .gallery-item__img-wrap {
    overflow: hidden;
    line-height: 0;
  }
  .gallery-item__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.55s ease;
    filter: saturate(0.9);
  }
  .gallery-item:hover .gallery-item__img-wrap img {
    transform: scale(1.06);
    filter: saturate(1.1);
  }

  /* Caption overlay */

  /* Size variants for visual interest */
  .gallery-item--tall .gallery-item__img-wrap img {
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  .gallery-item--wide .gallery-item__img-wrap img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .gallery-item--normal .gallery-item__img-wrap img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  /* Subtle shadow on hover */
  .gallery-item::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(42, 27, 56, 0.35);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .gallery-item:hover::after {
    opacity: 1;
  }

  @keyframes galleryFadeIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Lightbox (CSS-only via :target) ────────────── */

  /* ── Closing Quote ──────────────────────────────── */
  .gallery-closing {
    padding: var(--space-2xl) var(--space-lg);
    text-align: center;
  }
  .gallery-closing blockquote {
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-style: italic;
    color: var(--color-accent);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.4;
    position: relative;
    padding: 0;
    border: none;
  }
  .gallery-closing blockquote::before {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: var(--color-cta);
    margin: 0 auto var(--space-lg);
    border-radius: 2px;
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 1024px) {
    .gallery-grid {
      columns: 2;
    }
  }
  @media (max-width: 600px) {
    .gallery-hero {
      height: 55vh;
    }
    .gallery-hero__content {
      padding: var(--space-lg) var(--space-md);
    }
    .gallery-grid {
      columns: 1;
      column-gap: 0;
    }
    .gallery-section {
      padding: var(--space-lg) var(--space-sm);
    }
    .gallery-item__caption {
      transform: translateY(0);
    }
  }
</style>
